{
  "name": "knit-helper-4000",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Knit-Helper 4000 — a static knitting pattern generator.",
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @knit-helper-4000/app",
    "build": "npm run build --workspace @knit-helper-4000/app",
    "preview": "npm run preview --workspace @knit-helper-4000/app",
    "test": "npm run test --workspace @knit-helper-4000/engine",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  }
}
